# MQTT (Mosquitto)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC=centinela/evento
MQTT_CLIENT_ID=centinela-iot-bridge

# NATS (mismo broker que ms-core)
NATS_SERVERS=nats://localhost:4222

# PostgreSQL (misma BD que ms-core, schema app)
DATABASE_URL=postgresql://postgres:123@localhost:5432/coreDB

# Almacenamiento local de clips WAV
AUDIO_STORAGE_PATH=./data/audio

# HTTP
HTTP_PORT=8100
HTTP_HOST=0.0.0.0

# Reglas fase 1 (sin YAMNet)
SEVERIDAD_UMBRAL_DB=80
